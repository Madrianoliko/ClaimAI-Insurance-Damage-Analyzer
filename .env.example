# Skopiuj ten plik do backend/.env i uzupełnij wartości
# NIGDY nie commituj pliku .env do gita!

# OpenAI API Key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Roboflow API Key — https://app.roboflow.com/ → Settings → API Keys
ROBOFLOW_API_KEY=...

# Roboflow Model ID — format: "model-name/version"
# Polecane modele z Roboflow Universe:
#   - car-damage-detection-zber5/1
#   - vehicle-damage-ghodw/1
# Znajdź na: https://universe.roboflow.com/search?q=car+damage
ROBOFLOW_MODEL_ID=car-damage-detection-zber5/1

# URL frontendu (tylko na Railway/produkcja — lokalnie nie potrzebne)
# FRONTEND_URL=https://claimai-frontend.up.railway.app

# Port backendu (domyślnie 3001 lokalnie, Railway ustawia automatycznie)
# PORT=3001
